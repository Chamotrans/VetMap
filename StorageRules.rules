rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function admin() {
      return signedIn()
        && firestore.exists(
          /databases/(default)/documents/users/$(request.auth.uid)
        )
        && firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.role == 'admin';
    }

    function validImage() {
      return request.resource.size > 0
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|heic|heif|webp)');
    }

    // Pending uploads are private to the author and moderators. A user cannot
    // overwrite another user's file or place a pending image in a public path.
    match /submissionUploads/{userId}/{submissionId}/{fileName} {
      allow read: if signedIn() && (request.auth.uid == userId || admin());
      allow create: if signedIn()
        && request.auth.uid == userId
        && validImage();
      allow update: if false;
      allow delete: if signedIn() && (request.auth.uid == userId || admin());
    }

    // Only an admin approval workflow may publish an image. Public content is
    // readable without exposing private user folders.
    match /public/{contentType}/{contentId}/{fileName} {
      allow read: if true;
      allow create, update: if admin() && validImage();
      allow delete: if admin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
